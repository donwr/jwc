{
  "compilerOptions": {
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "baseUrl": ".",
    "paths": {
      "libs/*": ["libs/*"],
      "components/*": ["components/*"],
      "context/*": ["context/*"],
      "app/*": ["app/*"],
      "@/*": ["./*"]
    },
    "skipLibCheck": true,
    "strict": false,
    "noEmit": true,
    "incremental": true,
    "module": "esnext",
    "esModuleInterop": true,
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "next-env.d.ts",
    ".next/types/**/*.ts",
    "**/*.ts",
    "**/*.tsx",
    "app/(pages)/(components)/customCursor/index.tsx",
    "app/(pages)/product/[handle]/page.js",
    "app/(pages)/home/page.js"
  ],
  "exclude": ["node_modules"]
}
