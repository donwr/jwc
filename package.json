{
  "name": "jess-personal-training",
  "description": "Jess Personal Training Berlin",
  "version": "1.0.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@9.4.0",
  "scripts": {
    "dev:storyblok": "npm-run-all -p dev https",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "https": "local-ssl-proxy --source 3010 --target 3000 --cert localhost.pem --key localhost-key.pem",
    "lint": "next lint",
    "analyze": "cross-env ANALYZE=true next build",
    "prepare": "husky",
    "npmrc": "npx npmrc-replace-env -w",
    "preinstall": "npx npm-force-resolutions"
  },
  "dependencies": {
    "@calcom/embed-react": "^1.5.0",
    "@next/bundle-analyzer": "^14.2.7",
    "@next/third-parties": "^14.2.4",
    "@phosphor-icons/react": "^2.1.7",
    "@serwist/next": "9.0.3",
    "@theatre/core": "^0.7.2",
    "@theatre/studio": "^0.7.2",
    "clsx": "^2.1.1",
    "cookie": "^0.6.0",
    "formik": "^2.4.6",
    "framer-motion": "^11.11.10",
    "gsap": "^3.12.5",
    "jsonwebtoken": "^9.0.2",
    "lenis": "1.1.4",
    "next": "14.2.4",
    "next-sitemap": "^4.2.3",
    "nookies": "^2.5.2",
    "postprocessing": "^6.35.5",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-helmet": "^6.1.0",
    "react-hook-form": "^7.53.0",
    "react-use": "^17.5.0",
    "resend": "4.0.1-alpha.0",
    "sass": "^1.77.6",
    "scheduler": "^0.23.2",
    "stats-gl": "^2.2.8",
    "stats.js": "^0.17.0",
    "tunnel-rat": "^0.1.2",
    "yup": "^1.4.0",
    "zustand": "4.5.2"
  },
  "devDependencies": {
    "@builder.io/partytown": "^0.10.2",
    "@cerner/duplicate-package-checker-webpack-plugin": "^2.6.0",
    "@next/eslint-plugin-next": "^14.2.4",
    "@svgr/webpack": "^8.1.0",
    "critters": "^0.0.22",
    "cross-env": "^7.0.3",
    "eslint-config-next": "^14.2.4",
    "eslint-config-prettier": "^9.1.0",
    "husky": "^9.0.11",
    "local-ssl-proxy": "^2.0.5",
    "npm-force-resolutions": "^0.0.10",
    "npm-run-all": "^4.1.5",
    "npmrc-replace-env": "^1.1.4",
    "prettier": "^3.3.2",
    "serwist": "9.0.3"
  },
  "pnpm": {
    "overrides": {
      "scheduler": "0.23.0",
      "eslint": "8.57.0",
      "@darkroom.engineering/tempus": "0.0.46"
    }
  },
  "lint-staged": {
    "*.js": "eslint --cache --fix",
    "*.{js,css,scss,md}": "prettier --write"
  },
  "resolutions": {
    "scheduler": "0.23.2",
    "minimatch": "^9.0.5"
  }
}
